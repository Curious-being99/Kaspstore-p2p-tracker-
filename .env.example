# KaspStore Tracker Configuration

# Port the tracker binds to (Default: 3000)
PORT=3000

# SECURITY: The tracker will block ALL traffic if this is not set.
# Use ?api_key=VALUE in your announce URLs.
TRACKER_API_KEY=

# Environment (development or production)
NODE_ENV=production

# EXPRESSTURN (1 TB/Month Primary Relay)
EXPRESSTURN_USERNAME=
EXPRESSTURN_PASSWORD=
